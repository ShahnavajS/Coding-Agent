# Production Coding Assistant environment template

# Backend host config
BACKEND_HOST=0.0.0.0
BACKEND_PORT=5000
WORKSPACE_PATH=./workspace
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
DEFAULT_PROVIDER=ollama
SHELL_TIMEOUT_SECONDS=30

# Cloud providers
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# Local / on-device model options
OLLAMA_BASE_URL=http://localhost:11434/api
LOCAL_MODEL_PATH=

# Logging / future telemetry
LOG_LEVEL=INFO
